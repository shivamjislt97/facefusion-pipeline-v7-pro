# ── Telegram ──────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_ID=your_telegram_user_id_here

# ── Dashboard ─────────────────────────────────────────────────────────────
DASHBOARD_ENABLED=1
DASHBOARD_PORT=7860
DASHBOARD_PUBLIC_URL=https://your-studio-url-here

# ── Mega Upload ───────────────────────────────────────────────────────────
MEGA_EMAIL=your_mega_email_here
MEGA_PASSWORD=your_mega_password_here

# ── Google Drive (fallback) ───────────────────────────────────────────────
GDRIVE_ENABLED=1
GDRIVE_REMOTE_NAME=gdrive
GDRIVE_FOLDER=gdrive:masterswap
DRIVE_TOKEN={"access_token":"...","token_type":"Bearer","refresh_token":"...","expiry":"..."}

# ── Pipeline ──────────────────────────────────────────────────────────────
EXECUTION_PROVIDER=cuda
EXECUTION_THREAD_COUNT=4
OUTPUT_VIDEO_ENCODER=h264_nvenc
FACE_SWAPPER_MODEL=inswapper_128_fp16
FACE_ENHANCER_MODEL=gfpgan_1.4
FACE_ENHANCER_BLEND=80
ENABLE_FACE_ENHANCER=1
BYPASS_CONTENT_ANALYSER=1

# ── Auto-sleep ────────────────────────────────────────────────────────────
AUTO_SLEEP_ENABLED=1
AUTO_SLEEP_MINUTES=30
SLEEP_TEST_MODE=0
